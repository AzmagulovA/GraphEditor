<Window x:Class="GraphEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Graph Editor System" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="#F8F8F8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <Border Grid.Column="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,1,0" Padding="15">
            <StackPanel>
                <TextBlock Text="Инструменты" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <GroupBox Header="Действия" Margin="0,0,0,20">
                    <StackPanel Margin="5">
                        <RadioButton Content="🖱 Курсор (Info)" IsChecked="True" Style="{StaticResource ModeButtonStyle}" x:Name="RbSelect"/>
                        <RadioButton Content="➕ Добавить узел" Style="{StaticResource ModeButtonStyle}" x:Name="RbAddNode"/>
                        <RadioButton Content="❌ Удалить узел" Style="{StaticResource ModeButtonStyle}" x:Name="RbRemoveNode"/>
                        <RadioButton Content="🔗 Связать узлы" Style="{StaticResource ModeButtonStyle}" x:Name="RbAddEdge"/>
                        <RadioButton Content="✂ Удалить связь" Style="{StaticResource ModeButtonStyle}" x:Name="RbRemoveEdge"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Параметры" Margin="0,0,0,20">
                    <StackPanel Margin="5">
                        <TextBlock Text="Вес по умолчанию:" Style="{StaticResource HeaderStyle}"/>
                        <TextBox x:Name="TbDefaultWeight" Padding="3" Text="1.0" HorizontalContentAlignment="Right"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="ПКМ - перемещение поля" FontSize="11" Foreground="Gray" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <!-- 1. Холст (Нижний слой) -->
            <Border ClipToBounds="True" Background="#EEE"
            MouseRightButtonDown="Viewport_MouseRightButtonDown"
            MouseRightButtonUp="Viewport_MouseRightButtonUp"
            MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
            MouseMove="Viewport_MouseMove"
            MouseLeftButtonDown="Viewport_MouseLeftButtonDown">

                <Canvas x:Name="GraphCanvas" Width="5000" Height="5000" Background="{StaticResource GraphGridBrush}">
                    <Canvas.RenderTransform>
                        <TranslateTransform x:Name="CanvasTranslate" X="-2500" Y="-2500"/>
                    </Canvas.RenderTransform>
                </Canvas>
            </Border>

            <!-- 2. Оверлей с кнопками (Верхний слой, Правый верхний угол) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20">
                <TextBlock Text="Отображать:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>

                <RadioButton x:Name="RbShowName" Content="Название" IsChecked="True" GroupName="ViewMode" 
                 Style="{StaticResource OverlayToggleStyle}" Click="OnViewModeChanged"/>

                <RadioButton x:Name="RbShowImportance" Content="Коэф. важности" GroupName="ViewMode" 
                 Style="{StaticResource OverlayToggleStyle}" Click="OnViewModeChanged"/>
            </StackPanel>

            <TextBlock Text="Рабочая область" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
               Margin="10" Foreground="#AAA" FontWeight="Bold" IsHitTestVisible="False"/>
        </Grid>
    </Grid>
</Window>